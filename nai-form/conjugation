<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nai-form Specialist (16 Qs)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
        @keyframes shake {
            10%, 90% { transform: translate3d(-1px, 0, 0); }
            20%, 80% { transform: translate3d(2px, 0, 0); }
            30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
            40%, 60% { transform: translate3d(4px, 0, 0); }
        }
        .correct-pop { animation: pop 0.4s ease-out; }
        @keyframes pop {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
        .mic-active { 
            animation: pulse 1.5s infinite; 
            background-color: #ef4444 !important; 
            box-shadow: 0 0 20px rgba(239, 68, 68, 0.6);
        }
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
    </style>
</head>
<body class="bg-slate-100 min-h-screen font-sans flex flex-col items-center p-4">

    <!-- Browser Check -->
    <div id="browser-warning" class="w-full max-w-md bg-amber-50 border-2 border-amber-400 p-4 rounded-2xl mb-4 text-xs font-bold text-amber-900 shadow-sm">
        <p>⚠️ Koder内では音が出ません！SafariやChromeで開き、マイクを許可してください。</p>
        <button onclick="testSound()" class="mt-2 w-full bg-amber-500 text-white py-1 rounded-lg text-[10px] font-black uppercase shadow-sm active:bg-amber-600">Sound Test</button>
    </div>

    <header class="w-full max-w-md bg-rose-700 text-white p-6 rounded-3xl shadow-xl mb-4 text-center">
        <h1 class="text-2xl font-bold italic underline decoration-rose-300">Nai-form Master 🎙️</h1>
        <div class="mt-4 flex justify-between px-2 text-sm font-bold bg-rose-800/50 py-2 rounded-xl">
            <div>Q: <span id="progress-val">1</span> / 16</div>
            <div>Score: <span id="score-val">0</span></div>
        </div>
        <div class="w-full bg-rose-900/30 h-2 rounded-full mt-3 overflow-hidden">
            <div id="progress-bar" class="bg-rose-300 h-full transition-all duration-300" style="width: 6.25%"></div>
        </div>
    </header>

    <main id="game-card" class="w-full max-w-md bg-white rounded-3xl shadow-2xl p-6 flex flex-col items-center transition-all border-b-8 border-rose-600">
        <div id="target-group" class="bg-rose-100 text-rose-700 px-4 py-1 rounded-full text-[10px] font-black mb-3 uppercase tracking-tighter">Group 1</div>
        <div class="text-slate-400 text-[10px] font-bold uppercase mb-1 italic">What is the Nai-form of:</div>
        <div id="base-verb-en" class="text-5xl font-black text-slate-800 mb-8 tracking-tight italic text-center underline decoration-rose-500 decoration-4">Drink</div>
        
        <div id="input-container" class="w-full space-y-4">
            <div class="flex items-center space-x-2">
                <input type="text" id="user-input" autocomplete="off" autofocus
                       class="flex-grow p-4 text-xl font-bold border-4 border-slate-100 rounded-2xl text-center focus:border-rose-500 focus:outline-none transition-all" 
                       placeholder="...">
                <button id="mic-btn" onclick="toggleVoiceInput()" 
                        class="w-14 h-14 flex items-center justify-center bg-rose-600 text-white rounded-2xl shadow-lg transition-all active:scale-90">
                    <svg id="mic-icon" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
                    </svg>
                </button>
            </div>
            <div id="listening-status" class="hidden text-center text-red-500 font-bold text-xs animate-pulse italic">Listening... / 聞き取り中...</div>
            <button id="submit-btn" onclick="checkAnswer()" class="w-full py-5 bg-rose-600 text-white rounded-2xl font-black text-xl shadow-lg active:scale-95 transition-all">CHECK / 確認</button>
        </div>

        <div id="feedback" class="hidden mt-4 w-full text-center space-y-4">
            <div id="result-icon" class="text-5xl"></div>
            <div id="result-msg" class="font-black text-xl uppercase tracking-tighter"></div>
            <div class="bg-slate-50 p-5 rounded-2xl border-2 border-slate-100">
                <div id="display-kanji" class="text-3xl font-black text-slate-700 mb-1"></div>
                <div id="display-kana" class="text-xl font-bold text-rose-500 mb-2"></div>
                <div id="meanings-it" class="text-[10px] text-slate-400 border-t border-slate-200 pt-3 font-bold uppercase italic"></div>
            </div>
            <button id="next-btn" onclick="nextQuestion()" class="w-full py-4 bg-slate-800 text-white rounded-2xl font-black text-lg shadow-md transition-all">NEXT / 次へ →</button>
        </div>
    </main>

    <!-- Finished Screen -->
    <div id="finish-screen" class="hidden w-full max-w-md bg-white rounded-3xl shadow-2xl p-10 flex flex-col items-center text-center">
        <div class="text-6xl mb-6">Finished‼️</div>
        <p class="text-slate-500 font-bold uppercase tracking-widest mb-2 text-sm">Ottimo lavoro!</p>
        <div class="text-4xl font-black text-rose-700 mb-8">Score: <span id="final-score">0</span></div>
        <button onclick="location.reload()" class="w-full py-5 bg-rose-600 text-white rounded-2xl font-black text-xl shadow-lg active:scale-95 transition-all">RESTART / もう一度</button>
    </div>

    <script>
        const verbs = [
            { group: 1, en: "Go", it: "Andare", nai: { kanji: "行かない", kana: "いかない" } },
            { group: 1, en: "Drink", it: "Bere", nai: { kanji: "飲まない", kana: "のまない" } },
            { group: 1, en: "Return", it: "Tornare", nai: { kanji: "帰らない", kana: "かえらない" } },
            { group: 1, en: "Read", it: "Leggere", nai: { kanji: "読まない", kana: "よまない" } },
            { group: 1, en: "Write", it: "書かない", nai: { kanji: "かかない", kana: "かかない" } },
            { group: 1, en: "Listen", it: "聞かない", nai: { kanji: "聞かない", kana: "きかない" } },
            { group: 1, en: "Buy", it: "Comprare", nai: { kanji: "買わない", kana: "かわない" } },
            { group: 1, en: "Meet", it: "Incontrare", nai: { kanji: "会わない", kana: "あわない" } },
            { group: 1, en: "Wait", it: "Aspettare", nai: { kanji: "待たない", kana: "またない" } },
            { group: 1, en: "Speak", it: "Parlare", nai: { kanji: "話さない", kana: "はなさない" } },
            { group: 2, en: "Eat", it: "Mangiare", nai: { kanji: "食べない", kana: "たべない" } },
            { group: 2, en: "See", it: "Vedere", nai: { kanji: "見ない", kana: "みない" } },
            { group: 2, en: "Sleep", it: "Dormire", nai: { kanji: "寝ない", kana: "ねない" } },
            { group: 2, en: "Get up", it: "Alzarsi", nai: { kanji: "起きない", kana: "おきない" } },
            { group: 3, en: "Do", it: "Fare", nai: { kanji: "しない", kana: "しない" } },
            { group: 3, en: "Come", it: "Venire", nai: { kanji: "こない", kana: "こない" } }
        ];

        let shuffledVerbs = [...verbs].sort(() => Math.random() - 0.5);
        let currentIndex = 0;
        let score = 0;
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        let recognition = null, isListening = false;

        if (SpeechRecognition) {
            recognition = new SpeechRecognition();
            recognition.lang = 'ja-JP';
            recognition.onstart = () => { isListening = true; document.getElementById('mic-btn').classList.add('mic-active'); document.getElementById('listening-status').classList.remove('hidden'); };
            recognition.onend = () => { isListening = false; document.getElementById('mic-btn').classList.remove('mic-active'); document.getElementById('listening-status').classList.add('hidden'); };
            recognition.onresult = (event) => { 
                let transcript = event.results[0][0].transcript.replace(/[。、？！.?! ]/g, "");
                document.getElementById('user-input').value = transcript;
                setTimeout(checkAnswer, 400); 
            };
        }

        function toggleVoiceInput() { if (!recognition) return; if (isListening) recognition.stop(); else recognition.start(); }

        function updateDisplay() {
            const currentVerb = shuffledVerbs[currentIndex];
            document.getElementById('progress-val').innerText = currentIndex + 1;
            document.getElementById('progress-bar').style.width = ((currentIndex + 1) / 16 * 100) + "%";
            document.getElementById('target-group').innerText = `Group ${currentVerb.group}`;
            document.getElementById('base-verb-en').innerText = currentVerb.en;
        }

        function checkAnswer() {
            const userInput = document.getElementById('user-input').value.trim();
            if (!userInput && !isListening) return;
            const currentVerb = shuffledVerbs[currentIndex];
            const correctData = currentVerb.nai;
            const isCorrect = (userInput === correctData.kanji || userInput === correctData.kana);

            if (isCorrect) {
                score += 10;
                document.getElementById('result-icon').innerText = "✅";
                document.getElementById('result-msg').innerText = "Correct!";
                document.getElementById('result-msg').className = "font-black text-xl text-green-600 uppercase tracking-tighter";
                document.getElementById('game-card').classList.add('correct-pop');
                setTimeout(() => document.getElementById('game-card').classList.remove('correct-pop'), 400);
                speak(correctData.kana);
            } else {
                document.getElementById('result-icon').innerText = "❌";
                document.getElementById('result-msg').innerText = "Try Again";
                document.getElementById('result-msg').className = "font-black text-xl text-red-600 uppercase tracking-tighter";
                document.getElementById('game-card').classList.add('shake');
                setTimeout(() => document.getElementById('game-card').classList.remove('shake'), 500);
            }
            document.getElementById('score-val').innerText = score;
            document.getElementById('display-kanji').innerText = correctData.kanji;
            document.getElementById('display-kana').innerText = correctData.kana;
            document.getElementById('meanings-it').innerText = `Italian: ${currentVerb.it}`;
            document.getElementById('feedback').classList.remove('hidden');
            document.getElementById('input-container').classList.add('hidden');
        }

        function nextQuestion() {
            currentIndex++;
            if (currentIndex >= 16) {
                document.getElementById('game-card').classList.add('hidden');
                document.getElementById('finish-screen').classList.remove('hidden');
                document.getElementById('final-score').innerText = score;
                speak("お疲れ様でした。練習が終わりました。");
                return;
            }
            document.getElementById('feedback').classList.add('hidden');
            document.getElementById('input-container').classList.remove('hidden');
            document.getElementById('user-input').value = "";
            document.getElementById('user-input').focus();
            updateDisplay();
        }

        function speak(text) {
            if (!window.speechSynthesis) return;
            window.speechSynthesis.cancel();
            const ut = new SpeechSynthesisUtterance(text);
            ut.lang = 'ja-JP'; ut.rate = 0.8; window.speechSynthesis.speak(ut);
        }

        function testSound() { speak("準備ができました。"); alert("音が出ますか？"); }

        document.getElementById('user-input').addEventListener('keypress', (e) => { 
            if (e.key === 'Enter') {
                if (document.getElementById('feedback').classList.contains('hidden')) checkAnswer();
                else nextQuestion();
            }
        });
        window.onload = updateDisplay;
    </script>
</body>
</html>

